{
  "name": "skills-viewer",
  "version": "0.3.0",
  "description": "Browse, search and manage your Claude Code skills, commands, agents and hooks in the browser",
  "license": "MIT",
  "author": "watanabeyu",
  "repository": {
    "type": "git",
    "url": "https://github.com/watanabeyu/skills-viewer"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "agents",
    "hooks",
    "cli",
    "browser",
    "viewer"
  ],
  "bin": {
    "skills-viewer": "build/cli.js"
  },
  "files": [
    "build/",
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "concurrently -k \"tsx watch src/cli.ts --no-open --port 4763\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "fix:eslint": "eslint . --fix",
    "fix:prettier": "prettier --write .",
    "format": "pnpm fix:eslint && pnpm fix:prettier",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node build/cli.js",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.10"
  }
}
